# ===== 运行时自动生成的数据（不纳入版本控制）=====
# 微信账号登录态、聊天文件、下载缓存等
# 首次启动容器后会自动创建
data/

# ===== 本地 Git 与编辑器临时文件 =====
.git/
.gitignore.bak
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ===== 日志与临时文件 =====
*.log
logs/
tmp/
*.pid

# ===== 构建产物 =====
*.deb
*.tar.gz
*.zip

# ===== 环境变量文件（可能含敏感信息）=====
.env
.env.local
.env.*.local
